{
  "name": "version-update",
  "version": "1.0.0",
  "description": "GitHub Action for automated version management based on conventional commits",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "echo ncc build src/index.js -o dist --source-map",
    "lint": "eslint .",
    "test": "npx vitest run",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragoscops/version-update.git"
  },
  "keywords": [
    "github",
    "actions",
    "version",
    "semver",
    "release",
    "conventional-commits"
  ],
  "author": "dragoscops",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dragoscops/version-update/issues"
  },
  "homepage": "https://github.com/dragoscops/version-update#readme",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@npmcli/git": "^5.0.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.0",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=18"
  }
}
