{
  "name": "bumpalicious",
  "version": "2.0.2",
  "description": "GitHub Action for automated version management based on conventional commits",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "cpd": "jscpd ./src",
    "prettify": "npx prettier --write \"./**/*.{js,json}\"",
    "-prepare": "npm run build",
    "test": "npx vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragoscops/version-update.git"
  },
  "keywords": [
    "github",
    "actions",
    "version",
    "semver",
    "release",
    "conventional-commits"
  ],
  "author": "dragoscops",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dragoscops/version-update/issues"
  },
  "homepage": "https://github.com/dragoscops/version-update#readme",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@iarna/toml": "^2.2.5",
    "@npmcli/git": "^5.0.0",
    "conventional-changelog": "^6.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "conventional-changelog-core": "^9.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "semver": "^7.6.0",
    "tiny-jsonc": "^1.0.2",
    "tinyglobby": "^0.2.13"
  },
  "devDependencies": {
    "@jscpd/badge-reporter": "^4.0.1",
    "@jscpd/html-reporter": "^4.0.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "prettier": "^3.5.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=18"
  }
}