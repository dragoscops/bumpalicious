{
  "name": "bumpalicious",
  "version": "202.1.0-alpha.3",
  "description": "GitHub Action for automated version management based on conventional commits",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run type-check && ncc build src/index.ts -o dist --target es2020 --minify",
    "build:dev": "tsc --noEmit && ncc build src/index.ts -o dist --target es2020 --source-map",
    "type-check": "tsc --noEmit",
    "cpd": "jscpd ./src",
    "prebuild": "rimraf ./dist",
    "prettify": "npx prettier --write \"./**/*.{js,json,ts,md}\"",
    "-prepare": "npm run build",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragoscops/version-update.git"
  },
  "keywords": [
    "github",
    "actions",
    "version",
    "semver",
    "release",
    "conventional-commits"
  ],
  "author": "dragoscops",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dragoscops/version-update/issues"
  },
  "homepage": "https://github.com/dragoscops/version-update#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@iarna/toml": "^2.2.5",
    "@npmcli/git": "^7.0.0",
    "conventional-changelog": "^7.1.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "conventional-changelog-core": "^9.0.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.2",
    "semver": "^7.7.3",
    "tiny-jsonc": "^1.0.2",
    "tinyglobby": "^0.2.15",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@jscpd/badge-reporter": "^4.0.1",
    "@jscpd/html-reporter": "^4.0.1",
    "@templ-project/eslint": "^1.2.2",
    "@templ-project/prettier": "^1.0.6",
    "@templ-project/tsconfig": "^0.4.2",
    "@templ-project/vitest": "^0.3.2",
    "@types/conventional-changelog-core": "^8.0.0",
    "@types/node": "^24.8.1",
    "@types/semver": "^7.7.1",
    "@vercel/ncc": "^0.38.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
